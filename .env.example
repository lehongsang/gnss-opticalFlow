# Kafka Configuration
# For local development: localhost:9092. For production/hybrid: use the cloud Kafka address.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=gnss-ai-worker
KAFKA_JOBS_TOPIC=gnss.media.process.jobs
KAFKA_RESULTS_TOPIC=gnss.media.process.results
KAFKA_ALERTS_TOPIC=gnss.alerts
KAFKA_CONSUMER_GROUP=gnss.media.process.jobs.group

# S3 / SeaweedFS Configuration
S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=change-me-s3-access-key
S3_SECRET_KEY=change-me-s3-secret-key
S3_BUCKET=medias
S3_REGION=us-east-1
S3_USE_SSL=False
S3_FORCE_PATH_STYLE=False

# Optical Flow Configuration
# mode: VECTORS or HEATMAP
DEFAULT_PROCESS_MODE=VECTORS
DEFAULT_IS_MOVING=True
